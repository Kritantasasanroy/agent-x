# ---- Core ----
APP_NAME=JobHunter AI
ENVIRONMENT=development            # development | production
DEBUG=true
API_BASE_URL=http://localhost:8000

# ---- Security (REQUIRED — generate strong values) ----
# JWT_SECRET: any long random string.  ENCRYPTION_KEY: 32-byte urlsafe base64 (Fernet).
# Generate ENCRYPTION_KEY:  python -c "from cryptography.fernet import Fernet;print(Fernet.generate_key().decode())"
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
ENCRYPTION_KEY=change-me-32-byte-urlsafe-base64-key=

# ---- Database ----
DATABASE_URL=postgresql+psycopg://jobhunter:jobhunter@db:5432/jobhunter
# local sqlite fallback (no docker): sqlite+pysqlite:///./jobhunter.db

# ---- Redis / Celery ----
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ---- Vector store ----
CHROMA_DIR=./storage/chroma
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ---- LLM providers (set at least one) ----
LLM_PROVIDER=anthropic            # anthropic | openai | gemini | ollama
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-pro
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# ---- Matching ----
MATCH_THRESHOLD=75
MAX_APPLICATIONS_PER_DAY=50

# ---- Storage ----
STORAGE_DIR=./storage

# ---- Email (outreach) ----
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# ---- Scrapers: enable ONLY what you are allowed to use ----
ENABLE_REMOTEOK=true
ENABLE_WEWORKREMOTELY=true
ENABLE_YCOMBINATOR=true
ENABLE_LINKEDIN=false             # ToS-restricted — stub, off by default
ENABLE_INDEED=false               # ToS-restricted — stub, off by default
ENABLE_NAUKRI=false               # ToS-restricted — stub, off by default
ENABLE_GLASSDOOR=false            # ToS-restricted — stub, off by default
ENABLE_WELLFOUND=false            # ToS-restricted — stub, off by default
ENABLE_FOUNDIT=false              # ToS-restricted — stub, off by default

# ---- Frontend ----
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
