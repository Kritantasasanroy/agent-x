# ---- Core ----
APP_NAME=JobHunter AI
ENVIRONMENT=development            # development | production
DEBUG=true
API_BASE_URL=http://localhost:8000

# ---- Security (REQUIRED — generate strong values) ----
# JWT_SECRET: any long random string.  ENCRYPTION_KEY: 32-byte urlsafe base64 (Fernet).
# Generate ENCRYPTION_KEY:  python -c "from cryptography.fernet import Fernet;print(Fernet.generate_key().decode())"
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
ENCRYPTION_KEY=change-me-32-byte-urlsafe-base64-key=

# ---- Database ----
DATABASE_URL=postgresql+psycopg://jobhunter:jobhunter@db:5432/jobhunter
# local sqlite fallback (no docker): sqlite+pysqlite:///./jobhunter.db

# ---- Redis / Celery ----
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ---- Vector store ----
CHROMA_DIR=./storage/chroma
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ---- LLM providers (set at least one) ----
LLM_PROVIDER=anthropic            # anthropic | openai | gemini | ollama
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-pro
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# ---- Matching ----
MATCH_THRESHOLD=75
MAX_APPLICATIONS_PER_DAY=50

# ---- Storage ----
STORAGE_DIR=./storage

# ---- Email (outreach) ----
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# ---- Scrapers: enable ONLY what you are allowed to use ----
ENABLE_REMOTEOK=true
ENABLE_WEWORKREMOTELY=true
ENABLE_YCOMBINATOR=true
# Company ATS boards — public JSON APIs, automation-friendly (best auto-apply targets).
# Set the *_BOARDS/_COMPANIES/_ORGS lists to the company slugs you want (comma-separated).
ENABLE_GREENHOUSE=true
ENABLE_LEVER=true
ENABLE_ASHBY=true
GREENHOUSE_BOARDS=stripe,gitlab,airbnb     # slug in boards.greenhouse.io/<slug>
LEVER_COMPANIES=leverdemo                  # slug in jobs.lever.co/<slug>
ASHBY_ORGS=openai,posthog,linear,ramp      # slug in jobs.ashbyhq.com/<slug>
ENABLE_LINKEDIN=false             # ToS-restricted — stub, off by default
ENABLE_INDEED=false               # ToS-restricted — stub, off by default
ENABLE_NAUKRI=false               # ToS-restricted — stub, off by default
ENABLE_GLASSDOOR=false            # ToS-restricted — stub, off by default
ENABLE_WELLFOUND=false            # ToS-restricted — stub, off by default
ENABLE_FOUNDIT=false              # ToS-restricted — stub, off by default

# ---- Apply safety ----
# Real network application submissions happen ONLY when this is true. Leave false until
# you've reviewed the generated resumes/answers; flip on to let it actually apply.
ENABLE_REAL_APPLY=false

# ---- Notifications (CAPTCHA / needs-review alerts) ----
# Telegram is instant + free. Create a bot via @BotFather -> token; get your chat id from
# @userinfobot. If unset, alerts fall back to email (NOTIFY_EMAIL), else just logs.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
NOTIFY_EMAIL=

# ---- Frontend ----
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
